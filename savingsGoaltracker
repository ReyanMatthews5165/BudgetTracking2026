import { useState } from 'react';
import { Target, TrendingUp } from 'lucide-react';

interface SavingsGoalTrackerProps {
  currentSavings?: number;
  goalAmount?: number;
  onSetGoal?: (goal: number) => void;
}

export default function SavingsGoalTracker({
  currentSavings = 0,
  goalAmount = 0,
  onSetGoal
}: SavingsGoalTrackerProps) {
  const [isSettingGoal, setIsSettingGoal] = useState(false);
  const [newGoal, setNewGoal] = useState('');

  const percentage = goalAmount > 0 ? Math.min((currentSavings / goalAmount) * 100, 100) : 0;

  const getMotivationalMessage = () => {
    if (goalAmount === 0) {
      return "Set a goal to start your savings journey!";
    }
    if (percentage === 0) {
      return "Every journey begins with a single step!";
    }
    if (percentage < 25) {
      return "Great start! Keep the momentum going!";
    }
    if (percentage < 50) {
      return "You're making progress! Stay focused!";
    }
    if (percentage < 75) {
      return "You're on track! Keep saving!";
    }
    if (percentage < 100) {
      return "Almost there! You've got this!";
    }
    return "Goal achieved! Time to set a new one!";
  };

  const handleSetGoal = () => {
    const goal = parseFloat(newGoal);
    if (!isNaN(goal) && goal > 0) {
      onSetGoal?.(goal);
      setIsSettingGoal(false);
      setNewGoal('');
    }
  };

  return (
    <div className="bg-white rounded-xl shadow-md overflow-hidden">
      {/* Header with gradient */}
      <div className="bg-gradient-to-r from-green-500 to-emerald-600 p-4">
        <div className="flex items-center gap-2 text-white">
          <Target className="h-5 w-5" />
          <h3 className="font-semibold">Savings Goal</h3>
        </div>
      </div>

      {/* Content */}
      <div className="p-4 space-y-4">
        {/* Goal amounts */}
        <div className="flex justify-between items-center">
          <div>
            <p className="text-xs text-gray-600">Current Saved</p>
            <p className="text-2xl font-bold text-gray-900">
              ${currentSavings.toFixed(0)}
            </p>
          </div>
          <div className="text-right">
            <p className="text-xs text-gray-600">Goal Amount</p>
            <p className="text-2xl font-bold text-green-600">
              ${goalAmount.toFixed(0)}
            </p>
          </div>
        </div>

        {/* Progress bar */}
        <div className="space-y-2">
          <div className="relative w-full h-8 bg-gray-100 rounded-full overflow-hidden">
            {/* Progress fill */}
            <div
              className="absolute inset-y-0 left-0 bg-gradient-to-r from-green-400 to-green-600 rounded-full transition-all duration-700 ease-out flex items-center justify-end pr-2"
              style={{ width: `${percentage}%` }}
            >
              {percentage > 15 && (
                <span className="text-white text-xs font-semibold">
                  {Math.round(percentage)}%
                </span>
              )}
            </div>
            {/* Percentage outside bar if too small */}
            {percentage > 0 && percentage <= 15 && (
              <div className="absolute inset-0 flex items-center justify-center">
                <span className="text-gray-600 text-xs font-semibold">
                  {Math.round(percentage)}%
                </span>
              </div>
            )}
          </div>

          {/* Percentage display */}
          <div className="flex justify-between items-center">
            <span className="text-xs text-gray-500">
              ${(goalAmount - currentSavings).toFixed(0)} remaining
            </span>
            <span className="text-xs font-semibold text-green-600">
              {Math.round(percentage)}% complete
            </span>
          </div>
        </div>

        {/* Motivational message */}
        <div className="bg-green-50 border border-green-200 rounded-lg p-3 flex items-start gap-2">
          <TrendingUp className="h-4 w-4 text-green-600 mt-0.5 flex-shrink-0" />
          <p className="text-sm text-green-800 font-medium">
            {getMotivationalMessage()}
          </p>
        </div>

        {/* Set Goal Section */}
        {isSettingGoal ? (
          <div className="space-y-2">
            <div className="flex gap-2">
              <input
                type="number"
                placeholder="Enter goal amount"
                value={newGoal}
                onChange={(e) => setNewGoal(e.target.value)}
                className="flex-1 px-3 py-2 border border-gray-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-green-500 focus:border-transparent"
                autoFocus
              />
              <button
                onClick={handleSetGoal}
                className="px-4 py-2 bg-green-600 text-white rounded-lg hover:bg-green-700 transition-colors"
              >
                Save
              </button>
            </div>
            <button
              onClick={() => {
                setIsSettingGoal(false);
                setNewGoal('');
              }}
              className="text-sm text-gray-600 hover:text-gray-800"
            >
              Cancel
            </button>
          </div>
        ) : (
          <button
            onClick={() => setIsSettingGoal(true)}
            className="w-full bg-green-600 text-white py-3 rounded-lg hover:bg-green-700 transition-colors shadow-sm hover:shadow-md"
          >
            {goalAmount === 0 ? 'Set Goal' : 'Update Goal'}
          </button>
        )}
      </div>
    </div>
  );
}
